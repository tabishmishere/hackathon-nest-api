// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  PARTICIPANT
}

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  passwordHash String
  name         String
  role         Role        @default(PARTICIPANT)

  createdHackathons Hackathon[] @relation("CreatorHackathons")

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Hackathon {
  id              String   @id @default(uuid())
  title           String
  description     String
  startDate       DateTime
  endDate         DateTime
  maxParticipants Int

  creatorId       String
  creator         User     @relation("CreatorHackathons", fields: [creatorId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
